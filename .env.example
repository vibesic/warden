# ===== Backend =====
# Node environment: development | production | test
NODE_ENV=development

# Server port (default: 3333)
PORT=3333

# Server bind address (default: 0.0.0.0)
HOST=0.0.0.0

# Prisma database URL (SQLite)
DATABASE_URL=file:./data/dev.db

# HMAC-SHA256 secret for signing teacher auth tokens
# REQUIRED in production — omit to auto-generate a random secret per restart
TOKEN_SECRET=

# Teacher login password
# REQUIRED in production — defaults to "teacher" in development
TEACHER_PASSWORD=

# Comma-separated allowed CORS origins
# Omit for default localhost origins in development
CORS_ORIGINS=

# Directory for uploaded files (default: ./uploads)
UPLOADS_DIR=

# Absolute path to the built frontend directory (production only)
FRONTEND_PATH=

# Log level: silent | fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ===== Frontend (Vite) =====
# Backend API URL — Vite injects this at build time
# Omit for default localhost:3333 in development
VITE_API_URL=

# ===== Docker Registry =====
# Docker Hub registry username or namespace
DOCKER_USERNAME=
