FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Production stage
FROM node:20-alpine

WORKDIR /app

# Install simple static server
RUN npm install -g serve

COPY --from=builder /app/dist ./dist

EXPOSE 80

# Serve the static build on 0.0.0.0
CMD ["serve", "-s", "dist", "-l", "80"]
