generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id        String   @id @default(uuid())
  studentId String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionStudents SessionStudent[]
}

model SessionStudent {
  id            String    @id @default(uuid())
  ipAddress     String?
  deviceType    String?   // desktop | mobile | tablet
  deviceOs      String?   // Windows 11, Android 14, iOS 17, etc.
  deviceBrowser String?   // Chrome 120, Safari 17, etc.
  isOnline      Boolean   @default(false)
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student   Student @relation(fields: [studentId], references: [id])
  studentId String

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String

  violations  Violation[]
  submissions Submission[]

  @@unique([studentId, sessionId])
}

model Session {
  id              String   @id @default(uuid())
  code            String   @unique
  isActive        Boolean  @default(true)
  durationMinutes Int?
  createdAt       DateTime @default(now())
  endedAt         DateTime?

  sessionStudents SessionStudent[]
  submissions     Submission[]
}

model Violation {
  id        String   @id @default(uuid())
  type      String   // INTERNET_ACCESS | DISCONNECTION | CONNECTION_LOST | SNIFFER_TIMEOUT
  reason    String?  // Granular sub-reason: TAB_CLOSED | WIFI_LOST | PING_TIMEOUT | HEARTBEAT_TIMEOUT | CLIENT_PROBE | SERVER_SNIFFER | NETWORK_SWITCH | NO_RESPONSE | etc.
  timestamp DateTime @default(now())
  details   String?

  sessionStudent   SessionStudent @relation(fields: [sessionStudentId], references: [id])
  sessionStudentId String
}

model CheckTarget {
  id        String   @id @default(uuid())
  url       String   @unique
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Submission {
  id           String   @id @default(uuid())
  originalName String
  storedName   String
  mimeType     String?
  sizeBytes    Int
  createdAt    DateTime @default(now())

  sessionStudent   SessionStudent @relation(fields: [sessionStudentId], references: [id])
  sessionStudentId String

  session   Session @relation(fields: [sessionId], references: [id])
  sessionId String
}
